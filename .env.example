# Kibana connection -- set these in GitLab CI/CD > Settings > Variables
KIBANA_URL=https://your-kibana-instance:5601
KIBANA_SPACE=dev

# Authentication -- use ONE of the following methods:
# Option A: API Key (recommended)
KIBANA_API_KEY=your-api-key-here

# Option B: Username / Password
KIBANA_USER=elastic
KIBANA_PASSWORD=your-password-here
